generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  order     Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  estimates Estimate[]
  services  Service[]
  users     User[]     @relation("UserSpecialties")

  @@map("categories")
}

model Service {
  id         Int        @id @default(autoincrement())
  name       String
  categoryId Int
  order      Int        @default(0)
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  category   Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  estimates  Estimate[] @relation("EstimateServices")
  experts    User[]     @relation("ExpertServices")

  @@unique([name, categoryId])
  @@map("services")
}

model User {
  name                    String
  email                   String              @unique
  businessLicenseApproved Boolean             @default(false)
  businessLicenseUrls     String[]            @default([])
  career                  String?
  createdAt               DateTime            @default(now())
  emailVerified           DateTime?
  grade                   ExpertGrade?
  id                      Int                 @id @default(autoincrement())
  idCardApproved          Boolean             @default(false)
  idCardUrl               String?
  image                   String?
  isApproved              Boolean             @default(false)
  regions                 String[]            @default([])
  role                    UserRole            @default(USER)
  updatedAt               DateTime            @updatedAt
  bids                    Bid[]               @relation("ExpertBids")
  recvChats               Chat[]              @relation("ReceivedChats")
  sentChats               Chat[]              @relation("SentChats")
  profile                 Profile?            @relation("ExpertProfile")
  accounts                Account[]
  bookmarks               Bookmark[]          @relation("UserBookmarks")
  favoriteExperts         FavoriteExpert[]    @relation("UserFavoriteExperts")
  favoritedBy             FavoriteExpert[]    @relation("ExpertFavoritedBy")
  certifications          Certification[]     @relation("UserCertifications")
  payments                PaymentHistory[]    @relation("UserPayments")
  billingKeys             BillingKey[]        @relation("UserBillingKeys")

  // 구독 관련 필드
  subscriptionPlan        SubscriptionPlan    @default(LITE)
  subscriptionDate        DateTime?
  subscriptionEndDate     DateTime?
  subscriptionBillingCycle String             @default("MONTHLY") // MONTHLY | ANNUAL
  estimates               Estimate[]          @relation("CustomerEstimates")
  inquiries               Inquiry[]           @relation("UserInquiries")
  portfolioCategories     PortfolioCategory[] @relation("ExpertPortfolioCategories")
  portfolios              Portfolio[]         @relation("ExpertPortfolios")
  reports                 Report[]            @relation("UserReports")
  customerReviews         Review[]            @relation("CustomerReviews")
  expertReviews           Review[]            @relation("ExpertReviews")
  schedules               Schedule[]          @relation("ExpertSchedules")
  sessions                Session[]
  specialties             Category[]          @relation("UserSpecialties")
  expertServices          Service[]           @relation("ExpertServices")

  @@map("users")
}

model Profile {
  id             String   @id @default(uuid())
  expertId       Int      @unique
  introduction   String
  portfolioUrl   String?
  rating         Float    @default(0.0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  reviewCount    Int      @default(0)
  portfolioFiles String[] @default([])
  expert         User     @relation("ExpertProfile", fields: [expertId], references: [id], onDelete: Cascade)
}

model PortfolioCategory {
  id         Int         @id @default(autoincrement())
  expertId   Int
  name       String
  order      Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  expert     User        @relation("ExpertPortfolioCategories", fields: [expertId], references: [id], onDelete: Cascade)
  portfolios Portfolio[]

  @@map("portfolio_categories")
}

model Portfolio {
  id           Int                @id @default(autoincrement())
  expertId     Int
  categoryId   Int?
  title        String
  content      String
  thumbnailUrl String?
  blogUrl      String?
  isImported   Boolean            @default(false)
  seoTags      String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  category     PortfolioCategory? @relation(fields: [categoryId], references: [id])
  expert       User               @relation("ExpertPortfolios", fields: [expertId], references: [id], onDelete: Cascade)

  @@map("portfolios")
}

model Estimate {
  details             String
  status              EstimateStatus @default(PENDING)
  authorName          String?
  categoryId          Int?
  contact             String?
  createdAt           DateTime       @default(now())
  currentStep         Int            @default(1)
  customerId          Int
  designatedExpertId  Int?
  extendedDays        Int            @default(0)
  id                  String         @id @default(uuid())
  isClosed            Boolean        @default(false)
  isUrgent            Boolean        @default(false)
  location            String
  needsReestimate     Boolean        @default(false)
  photoUrls           String[]
  requestNumber       String?        @unique
  selectedDate        String?
  serviceDate         String?
  serviceTime         String?
  shareContact        Boolean        @default(false)
  updatedAt           DateTime       @updatedAt
  completionPhotoUrls String[]       @default([])
  bids                Bid[]          @relation("EstimateBids")
  chats               Chat[]         @relation("EstimateChats")
  bookmarks           Bookmark[]     @relation("EstimateBookmarks")
  payments            PaymentHistory[] @relation("EstimatePayments")
  category            Category?      @relation(fields: [categoryId], references: [id])
  customer            User           @relation("CustomerEstimates", fields: [customerId], references: [id], onDelete: Cascade)
  review              Review?        @relation("EstimateReview")
  services            Service[]      @relation("EstimateServices")

  @@map("estimates")
}

model Bookmark {
  id         String   @id @default(uuid())
  userId     Int
  estimateId String
  createdAt  DateTime @default(now())
  estimate   Estimate @relation("EstimateBookmarks", fields: [estimateId], references: [id], onDelete: Cascade)
  user       User     @relation("UserBookmarks", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, estimateId])
  @@map("bookmarks")
}

model FavoriteExpert {
  id        String   @id @default(uuid())
  userId    Int
  expertId  Int
  createdAt DateTime @default(now())
  
  user      User     @relation("UserFavoriteExperts", fields: [userId], references: [id], onDelete: Cascade)
  expert    User     @relation("ExpertFavoritedBy", fields: [expertId], references: [id], onDelete: Cascade)

  @@unique([userId, expertId])
  @@map("favorite_experts")
}

model PaymentHistory {
  id              String      @id @default(uuid())
  userId          Int
  paymentType     String      @default("SUBSCRIPTION")
  planName        String?     // 예: BASIC_MONTHLY / BASIC_ANNUAL
  billingCycle    String      @default("MONTHLY") // MONTHLY | ANNUAL
  billingMonths   Int         @default(1)          // 결제로 구매한 이용 개월 수 (월 1, 연간 12)
  amount          Int
  paymentDate     DateTime    @default(now())
  status          String      @default("PAID")
  nextPaymentDate DateTime?
  estimateId      String?
  // PG사 결제 연동 필드
  billingKeyId    String?     // 사용된 빌링키 참조 (정기결제 시)
  pgTransactionId String?     // PG사 거래 고유번호 (취소/환불 시 사용)
  failureReason   String?     // 결제 실패 사유

  user            User        @relation("UserPayments", fields: [userId], references: [id], onDelete: Cascade)
  estimate        Estimate?   @relation("EstimatePayments", fields: [estimateId], references: [id], onDelete: SetNull)
  billingKey      BillingKey? @relation("BillingKeyPayments", fields: [billingKeyId], references: [id], onDelete: SetNull)

  @@map("payment_history")
}

/// PG사에서 발급받은 빌링키(정기결제 토큰) 및 카드 마스킹 정보 저장 테이블.
/// 실제 카드 번호는 절대 저장하지 않으며, PG사 서버에 암호화된 카드 정보가 보관됩니다.
model BillingKey {
  id              String          @id @default(uuid())
  userId          Int                               // 전문가 userId
  pgProvider      PgProvider      @default(PORTONE) // 연동 PG사 구분
  billingKey      String                            // PG사 발급 빌링키 토큰 (정기결제 시 사용)
  customerKey     String?                           // PG사 고객 식별키 (토스페이먼츠 등)
  // 카드 마스킹 정보 (화면 표시용, 앞 6자리·뒤 4자리만 보관)
  cardCompany     String?                           // 카드사명 (예: 신한, 국민, 현대)
  cardType        String?                           // 카드 종류 (신용/체크)
  cardBin         String?                           // 카드 BIN (앞 6자리)
  cardLast4       String?                           // 카드 끝 4자리
  cardExpireYear  String?                           // 유효기간 년도 (YY)
  cardExpireMonth String?                           // 유효기간 월 (MM)
  holderName      String?                           // 카드 소유자명
  // 상태 및 메타데이터
  isActive        Boolean         @default(true)    // 현재 정기결제에 사용 중인 키 여부
  isDefault       Boolean         @default(false)   // 대표 결제 수단 여부
  issueSucceeded  Boolean         @default(false)   // 빌링키 발급 성공 여부
  failureMessage  String?                           // 발급 실패 메시지
  issuedAt        DateTime?                         // 빌링키 발급 완료 시각
  expiredAt       DateTime?                         // 빌링키 만료 시각 (PG사 정책에 따라)
  deletedAt       DateTime?                         // 소프트 삭제 시각
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user            User            @relation("UserBillingKeys", fields: [userId], references: [id], onDelete: Cascade)
  payments        PaymentHistory[] @relation("BillingKeyPayments")

  @@index([userId, isActive])
  @@index([userId, isDefault])
  @@map("billing_keys")
}

model Bid {
  id              String    @id @default(uuid())
  estimateId      String
  expertId        Int
  price           Int
  message         String?
  availableDate   String?
  status          BidStatus @default(PENDING)
  isEditRequested Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  estimate        Estimate  @relation("EstimateBids", fields: [estimateId], references: [id], onDelete: Cascade)
  expert          User      @relation("ExpertBids", fields: [expertId], references: [id], onDelete: Cascade)
  items           BidItem[] @relation("BidItems")
}

model BidItem {
  id      String @id @default(uuid())
  bidId   String
  name    String
  content String
  period  String
  amount  Int
  bid     Bid    @relation("BidItems", fields: [bidId], references: [id], onDelete: Cascade)

  @@map("bid_items")
}

model Chat {
  id         String    @id @default(uuid())
  senderId   Int
  receiverId Int
  estimateId String?
  message    String
  isRead     Boolean   @default(false)
  createdAt  DateTime  @default(now())
  estimate   Estimate? @relation("EstimateChats", fields: [estimateId], references: [id], onDelete: Cascade)
  receiver   User      @relation("ReceivedChats", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User      @relation("SentChats", fields: [senderId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Inquiry {
  id        String        @id @default(uuid())
  userId    Int
  target    String        @default("USER")
  type      String
  title     String
  content   String
  answer    String?
  status    InquiryStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation("UserInquiries", fields: [userId], references: [id], onDelete: Cascade)

  @@map("inquiries")
}

model Report {
  id        String   @id @default(uuid())
  userId    Int
  targetId  String?
  reason    String
  details   String
  createdAt DateTime @default(now())
  user      User     @relation("UserReports", fields: [userId], references: [id], onDelete: Cascade)

  @@map("reports")
}

model Notice {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  important Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notices")
}

model FAQ {
  id        Int      @id @default(autoincrement())
  target    String   @default("USER")
  category  String
  question  String
  answer    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faqs")
}

model Schedule {
  id        String   @id @default(uuid())
  expertId  Int
  date      String
  title     String
  content   String?
  amount    Int?     @default(0)
  isHoliday Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expert    User     @relation("ExpertSchedules", fields: [expertId], references: [id], onDelete: Cascade)

  @@map("schedules")
}

model Certification {
  id         String   @id @default(uuid())
  userId     Int
  name       String
  fileUrl    String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation("UserCertifications", fields: [userId], references: [id], onDelete: Cascade)

  @@map("certifications")
}

model Review {
  id         String   @id @default(uuid())
  estimateId String   @unique
  expertId   Int
  customerId Int
  rating     Float    @default(5.0)
  content    String
  photoUrls  String[] @default([])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   User     @relation("CustomerReviews", fields: [customerId], references: [id], onDelete: Cascade)
  estimate   Estimate @relation("EstimateReview", fields: [estimateId], references: [id], onDelete: Cascade)
  expert     User     @relation("ExpertReviews", fields: [expertId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

enum UserRole {
  USER
  EXPERT
  BOTH
  ADMIN
}

enum ExpertGrade {
  PRO
  HELPER
}

enum EstimateStatus {
  DRAFT
  PENDING
  BIDDING
  SELECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  INSPECTION
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum InquiryStatus {
  PENDING
  ANSWERED
}

enum SubscriptionPlan {
  LITE
  BASIC
}

/// 연동 PG사 구분
enum PgProvider {
  PORTONE      // 포트원 (구 아임포트) - 다수 PG사 통합
  TOSS         // 토스페이먼츠
  KAKAO        // 카카오페이
  NAVER        // 네이버페이
  KG_INICIS    // KG 이니시스
  NICE         // NHN KCP / 나이스페이
}

model SystemConfig {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_configs")
}
