generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  order     Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  estimates Estimate[]
  services  Service[]
  users     User[]     @relation("UserSpecialties")

  @@map("categories")
}

model Service {
  id         Int        @id @default(autoincrement())
  name       String
  categoryId Int
  order      Int        @default(0)
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  category   Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  estimates  Estimate[] @relation("EstimateServices")

  @@unique([name, categoryId])
  @@map("services")
}

model User {
  name                    String
  email                   String              @unique
  businessLicenseApproved Boolean             @default(false)
  businessLicenseUrls     String[]            @default([])
  career                  String?
  createdAt               DateTime            @default(now())
  emailVerified           DateTime?
  grade                   ExpertGrade?
  id                      Int                 @id @default(autoincrement())
  idCardApproved          Boolean             @default(false)
  idCardUrl               String?
  image                   String?
  isApproved              Boolean             @default(false)
  regions                 String[]            @default([])
  role                    UserRole            @default(USER)
  updatedAt               DateTime            @updatedAt
  bids                    Bid[]               @relation("ExpertBids")
  recvChats               Chat[]              @relation("ReceivedChats")
  sentChats               Chat[]              @relation("SentChats")
  profile                 Profile?            @relation("ExpertProfile")
  accounts                Account[]
  bookmarks               Bookmark[]          @relation("UserBookmarks")
  certifications          Certification[]     @relation("UserCertifications")
  estimates               Estimate[]          @relation("CustomerEstimates")
  inquiries               Inquiry[]           @relation("UserInquiries")
  portfolioCategories     PortfolioCategory[] @relation("ExpertPortfolioCategories")
  portfolios              Portfolio[]         @relation("ExpertPortfolios")
  reports                 Report[]            @relation("UserReports")
  customerReviews         Review[]            @relation("CustomerReviews")
  expertReviews           Review[]            @relation("ExpertReviews")
  schedules               Schedule[]          @relation("ExpertSchedules")
  sessions                Session[]
  specialties             Category[]          @relation("UserSpecialties")

  @@map("users")
}

model Profile {
  id             String   @id @default(uuid())
  expertId       Int      @unique
  introduction   String
  portfolioUrl   String?
  rating         Float    @default(0.0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  reviewCount    Int      @default(0)
  portfolioFiles String[] @default([])
  expert         User     @relation("ExpertProfile", fields: [expertId], references: [id], onDelete: Cascade)
}

model PortfolioCategory {
  id         Int         @id @default(autoincrement())
  expertId   Int
  name       String
  order      Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  expert     User        @relation("ExpertPortfolioCategories", fields: [expertId], references: [id], onDelete: Cascade)
  portfolios Portfolio[]

  @@map("portfolio_categories")
}

model Portfolio {
  id           Int                @id @default(autoincrement())
  expertId     Int
  categoryId   Int?
  title        String
  content      String
  thumbnailUrl String?
  blogUrl      String?
  isImported   Boolean            @default(false)
  seoTags      String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  category     PortfolioCategory? @relation(fields: [categoryId], references: [id])
  expert       User               @relation("ExpertPortfolios", fields: [expertId], references: [id], onDelete: Cascade)

  @@map("portfolios")
}

model Estimate {
  details             String
  status              EstimateStatus @default(PENDING)
  authorName          String?
  categoryId          Int?
  contact             String?
  createdAt           DateTime       @default(now())
  currentStep         Int            @default(1)
  customerId          Int
  designatedExpertId  Int?
  extendedDays        Int            @default(0)
  id                  String         @id @default(uuid())
  isClosed            Boolean        @default(false)
  isUrgent            Boolean        @default(false)
  location            String
  needsReestimate     Boolean        @default(false)
  photoUrls           String[]
  requestNumber       String?        @unique
  selectedDate        String?
  serviceDate         String?
  serviceTime         String?
  shareContact        Boolean        @default(false)
  updatedAt           DateTime       @updatedAt
  completionPhotoUrls String[]       @default([])
  bids                Bid[]          @relation("EstimateBids")
  chats               Chat[]         @relation("EstimateChats")
  bookmarks           Bookmark[]     @relation("EstimateBookmarks")
  category            Category?      @relation(fields: [categoryId], references: [id])
  customer            User           @relation("CustomerEstimates", fields: [customerId], references: [id], onDelete: Cascade)
  review              Review?        @relation("EstimateReview")
  services            Service[]      @relation("EstimateServices")

  @@map("estimates")
}

model Bookmark {
  id         String   @id @default(uuid())
  userId     Int
  estimateId String
  createdAt  DateTime @default(now())
  estimate   Estimate @relation("EstimateBookmarks", fields: [estimateId], references: [id], onDelete: Cascade)
  user       User     @relation("UserBookmarks", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, estimateId])
  @@map("bookmarks")
}

model Bid {
  id              String    @id @default(uuid())
  estimateId      String
  expertId        Int
  price           Int
  message         String?
  availableDate   String?
  status          BidStatus @default(PENDING)
  isEditRequested Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  estimate        Estimate  @relation("EstimateBids", fields: [estimateId], references: [id], onDelete: Cascade)
  expert          User      @relation("ExpertBids", fields: [expertId], references: [id], onDelete: Cascade)
  items           BidItem[] @relation("BidItems")
}

model BidItem {
  id      String @id @default(uuid())
  bidId   String
  name    String
  content String
  period  String
  amount  Int
  bid     Bid    @relation("BidItems", fields: [bidId], references: [id], onDelete: Cascade)

  @@map("bid_items")
}

model Chat {
  id         String    @id @default(uuid())
  senderId   Int
  receiverId Int
  estimateId String?
  message    String
  isRead     Boolean   @default(false)
  createdAt  DateTime  @default(now())
  estimate   Estimate? @relation("EstimateChats", fields: [estimateId], references: [id], onDelete: Cascade)
  receiver   User      @relation("ReceivedChats", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User      @relation("SentChats", fields: [senderId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Inquiry {
  id        String        @id @default(uuid())
  userId    Int
  type      String
  title     String
  content   String
  answer    String?
  status    InquiryStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation("UserInquiries", fields: [userId], references: [id], onDelete: Cascade)

  @@map("inquiries")
}

model Report {
  id        String   @id @default(uuid())
  userId    Int
  targetId  String?
  reason    String
  details   String
  createdAt DateTime @default(now())
  user      User     @relation("UserReports", fields: [userId], references: [id], onDelete: Cascade)

  @@map("reports")
}

model Notice {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  important Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notices")
}

model FAQ {
  id        Int      @id @default(autoincrement())
  category  String
  question  String
  answer    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faqs")
}

model Schedule {
  id        String   @id @default(uuid())
  expertId  Int
  date      String
  title     String
  content   String?
  amount    Int?     @default(0)
  isHoliday Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expert    User     @relation("ExpertSchedules", fields: [expertId], references: [id], onDelete: Cascade)

  @@map("schedules")
}

model Certification {
  id         String   @id @default(uuid())
  userId     Int
  name       String
  fileUrl    String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation("UserCertifications", fields: [userId], references: [id], onDelete: Cascade)

  @@map("certifications")
}

model Review {
  id         String   @id @default(uuid())
  estimateId String   @unique
  expertId   Int
  customerId Int
  rating     Float    @default(5.0)
  content    String
  photoUrls  String[] @default([])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   User     @relation("CustomerReviews", fields: [customerId], references: [id], onDelete: Cascade)
  estimate   Estimate @relation("EstimateReview", fields: [estimateId], references: [id], onDelete: Cascade)
  expert     User     @relation("ExpertReviews", fields: [expertId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

enum UserRole {
  USER
  EXPERT
  BOTH
  ADMIN
}

enum ExpertGrade {
  PRO
  HELPER
}

enum EstimateStatus {
  DRAFT
  PENDING
  BIDDING
  SELECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  INSPECTION
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum InquiryStatus {
  PENDING
  ANSWERED
}
